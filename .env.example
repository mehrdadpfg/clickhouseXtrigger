# Copy to .env and fill in. Both Next.js and `trigger.dev dev` read .env.
#
# NOTE: .env only covers LOCAL dev. Trigger.dev tasks that run DEPLOYED execute
# in Trigger's cloud and cannot see this file — the same vars must also be set in
# the Trigger.dev dashboard under Environment Variables. See README.

# --- Trigger.dev -------------------------------------------------------------
# DEV secret key: dashboard -> project -> API Keys.
# Used by the server actions (createStartSessionAction / createPublicToken).
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxx

# --- Anthropic ---------------------------------------------------------------
# Used by the chat.agent task.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Resend (watcher alert emails) -------------------------------------------
# OPTIONAL. With no key, a tripped watcher still alerts on the Watch page — it
# just doesn't email (a logged no-op, never a crashed tick). Set the key to turn
# email on. Get one at https://resend.com -> API Keys.
# NOTE: like all task env, this must ALSO be set in the Trigger.dev dashboard for
# DEPLOYED runs — the watcher-notify task runs in Trigger's cloud.
RESEND_API_KEY=re_xxxxxxxx
# From address. Defaults to Resend's zero-setup test sender (no domain to verify).
# Use a verified-domain address for real delivery.
RESEND_FROM=onboarding@resend.dev

# --- App --------------------------------------------------------------------
# Absolute base URL used for the "open the watcher" link in alert emails. A task
# runs with no request to infer the host from, so it is configured here.
APP_BASE_URL=http://localhost:3000

# --- ClickHouse (analytical data plane) --------------------------------------
# Full connection string incl. credentials. Build it in the env, never in code.
# Host = the service's HTTPS endpoint (port 8443).
CLICKHOUSE_URL=https://default:PASSWORD@your-service.region.gcp.clickhouse.cloud:8443

# --- Postgres (app state: chats, watchers, alerts, boards) -------------------
# Query history is NOT stored here — it comes from ClickHouse system.query_log.
# ClickHouse Cloud managed Postgres or any provider. Standard libpq vars;
# node-postgres reads them natively, so we pass them through rather than
# re-assembling a URL. TLS is on (managed Postgres terminates it at a proxy).
PGHOST=your-service.region.gcp.clickhouse.cloud
PGPORT=5432
PGUSER=user
PGPASSWORD=PASSWORD
PGDATABASE=vantage
